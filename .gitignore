# --- Project-specific scratch ---
# Keep `benchmark/cpu_baseline/` (reference dumps) and `benchmark/pdb_panel.csv`
# under version control; ignore only ad-hoc result CSVs / .npz dumps placed
# at the benchmark root that aren't the curated reference data.
benchmark/*.csv
!benchmark/pdb_panel.csv
benchmark/gpu_outputs/
benchmark/*.npz
benchmark/_*

# Scratch / spike files at repo root
_*.py
_*.json
_spike_*/
_inspect_*/

# Local results dump
results/*.csv
results/*.npz
results/*.html

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# OS files
*.log
*.tmp
